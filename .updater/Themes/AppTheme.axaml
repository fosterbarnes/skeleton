<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource ThemeFormBgBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ThemeMainTextBrush}" />
  </Style>

  <StyleInclude Source="avares://updater/Themes/Controls/Button.axaml" />
  <StyleInclude Source="avares://updater/Themes/Controls/TextBox.axaml" />
  <StyleInclude Source="avares://updater/Themes/Controls/ComboBox.axaml" />
  <StyleInclude Source="avares://updater/Themes/Controls/CheckBox.axaml" />
  <StyleInclude Source="avares://updater/Themes/Controls/ScrollViewer.axaml" />

</Styles>
