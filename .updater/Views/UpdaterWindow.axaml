<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="using:skeleton.UI"
        xmlns:vm="using:skeleton.Updater.ViewModels"
        x:Class="skeleton.Updater.Views.UpdaterWindow"
        x:DataType="vm:UpdaterWindowViewModel"
        TextOptions.TextRenderingMode="SubpixelAntialias"
        TextOptions.TextHintingMode="Strong"
        TextOptions.BaselinePixelAlignment="Aligned"
        Title="{Binding TitleText}"
        Width="400"
        MinHeight="130"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

  <StackPanel Margin="{x:Static ui:UiMetrics.TabContentPadding}"
              Spacing="{x:Static ui:UiMetrics.AppSettingsControlGapPx}">
    <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" />
    <ProgressBar IsVisible="{Binding ProgressVisible}"
                 Value="{Binding ProgressValue}"
                 Minimum="0"
                 Maximum="100"
                 Height="{x:Static ui:UiMetrics.ControlHeight}" />
    <Button Content="{Binding ActionText}"
            Command="{Binding ActionCommand}"
            IsVisible="{Binding ActionVisible}"
            HorizontalAlignment="Stretch"
            Height="{x:Static ui:UiMetrics.ControlHeight}" />
  </StackPanel>
</Window>
