<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="using:skeleton.UI">

  <Style Selector="Border.app-status-bar">
    <Setter Property="Background" Value="{DynamicResource ThemeSurfaceBgBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ThemeMainBorderBrush}" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
    <Setter Property="Padding" Value="{x:Static ui:UiMetrics.StatusFooterPadding}" />
    <Setter Property="MinHeight" Value="{x:Static ui:UiMetrics.StatusFooterHeightPx}" />
  </Style>

  <Style Selector="Border.app-status-bar TextBlock.status-text">
    <Setter Property="FontFamily" Value="{DynamicResource ThemeFontMonoFamily}" />
    <Setter Property="FontSize" Value="{DynamicResource ThemeFontStatus}" />
    <Setter Property="Foreground" Value="{DynamicResource ThemeMainTextBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.app-status-bar Button">
    <Setter Property="MinWidth" Value="72" />
  </Style>

</Styles>
